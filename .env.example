# ============================================================
# Shrayak: Shramik Sahayak — Environment Configuration
# SECURITY: Never commit .env to version control.
# Copy this file to .env and fill in real values.
# ============================================================

# --- Elastic Cloud ---
# Elastic Cloud ID (from cloud.elastic.co → Deployment → Copy Cloud ID)
ELASTIC_CLOUD_ID=your_elastic_cloud_id_here

# Elastic API Key (Kibana → Stack Management → API Keys → Create)
# Permissions needed: indices:data/write, indices:data/read, indices:admin/create
ELASTIC_API_KEY=your_base64_encoded_api_key_here

# Elasticsearch Index Names
ELASTIC_INDEX_DOCS=shrayak-docs
ELASTIC_INDEX_LOGS=shrayak-apm-logs

# --- Google Gemini API ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model for chat (flash = fastest, cost-effective for prod)
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Gemini model for embeddings (768 dimensions)
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Server ---
PORT=3000
NODE_ENV=development

# Allowed CORS origins (comma-separated for production)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate Limiting ---
# Requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=50

# --- Security ---
# Minimum query length (chars)
MIN_QUERY_LENGTH=3

# Maximum query length (chars) — defends against prompt stuffing
MAX_QUERY_LENGTH=2000

# --- APM / Observability ---
# Set to 'true' to enable detailed APM spans in Elastic
ENABLE_APM=true

# APM Server URL (Elastic Cloud → APM → Agents)
# Leave blank if using managed Elastic APM (cloud default)
ELASTIC_APM_SERVER_URL=
ELASTIC_APM_SECRET_TOKEN=
